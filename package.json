{
  "name": "flowmatrixai-com",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate:deployment": "node scripts/validate-deployment-config.mjs",
    "validate:content": "npm run validate:deployment",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite-ssg build",
    "postbuild": "npm run sitemap:generate && npm run robots:generate && npm run validate:head-artifacts",
    "sitemap:generate": "node scripts/generate-sitemap.mjs",
    "robots:generate": "node scripts/generate-robots.mjs",
    "validate:head-artifacts": "node scripts/validate-head-artifacts.mjs",
    "validate:build-artifacts": "node scripts/validate-build-artifacts.mjs",
    "preview": "vite preview",
    "typecheck": "vue-tsc --build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@unhead/vue": "^1.11.20",
    "vite-ssg": "^27.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260306.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.11",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.1.10"
  },
  "lint-staged": {
    "*.{ts,vue,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
