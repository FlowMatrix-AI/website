# Canonical domain used for SEO tags and sitemap URLs.
# Staging default: https://flowmatrix-ai.github.io
# Production cutover: https://flowmatrixai.com
VITE_SITE_URL=https://flowmatrix-ai.github.io

# Indexing mode. Keep false on staging, set true on production.
VITE_ALLOW_INDEXING=false

# Google Analytics 4 measurement ID (optional).
# Leave unset/blank to skip GA loading and events.
VITE_GA_MEASUREMENT_ID=G-REPLACE_ME
